# Application
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:8081

# Database (PostgreSQL + TimescaleDB)
DATABASE_URL=postgresql://wellmatch:wellmatch_secret@localhost:5432/wellmatch

# Cache
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=change-this-to-a-strong-random-secret-in-production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Rate limiting
RATE_LIMIT_TTL=60000
RATE_LIMIT_LIMIT=60

# Matching
MAX_SWIPES_PER_DAY=50

# Supabase Auth (optional alternative to JWT)
SUPABASE_URL=
SUPABASE_KEY=

# Storage (for avatars - optional)
STORAGE_BUCKET=
STORAGE_ENDPOINT=


